---
import Layout from '../layouts/Layout.astro';

const featuredPosts = [
  {
    slug: 'getting-started-with-ceramics',
    title: 'Getting Started with Ceramics',
    date: 'March 28, 2026',
    excerpt: 'My journey into hand-building pottery — the tools, clay bodies, and first firings that changed everything.',
    tag: 'Craft',
  },
  {
    slug: 'design-principles-i-live-by',
    title: 'Design Principles I Live By',
    date: 'March 12, 2026',
    excerpt: 'Simplicity, intentionality, and leaving room for imperfection. How these ideas shape my work every day.',
    tag: 'Design',
  },
  {
    slug: 'small-batch-production',
    title: 'Why I Switched to Small Batch',
    date: 'February 20, 2026',
    excerpt: 'Dropping mass production in favour of limited runs — and why my work (and life) is better for it.',
    tag: 'Business',
  },
];

const featuredProducts = [
  {
    id: 1,
    name: 'Stoneware Mug – Ash Glaze',
    price: 48,
    tag: 'Ceramics',
    emoji: '🏺',
    description: 'Wheel-thrown, food-safe, dishwasher safe. Each piece unique.',
  },
  {
    id: 2,
    name: 'Linen Tote Bag',
    price: 32,
    tag: 'Textiles',
    emoji: '👜',
    description: 'Natural linen, hand-stitched seams, block-printed design.',
  },
  {
    id: 3,
    name: 'Field Notes Zine Vol. 1',
    price: 14,
    tag: 'Print',
    emoji: '📖',
    description: '24-page riso-printed zine on craft, process, and place.',
  },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 py-24 text-center">
    <span class="inline-block bg-amber-100 text-amber-700 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-6">
      Handmade & Thoughtful
    </span>
    <h1 class="text-5xl md:text-6xl font-bold text-stone-900 leading-tight mb-6">
      Work made with<br />
      <span class="text-amber-500">care and intention.</span>
    </h1>
    <p class="text-lg text-stone-500 max-w-xl mx-auto mb-10">
      I'm Sukriti — a maker, writer, and designer. This is my small corner of the internet where I share my process and sell my work.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/shop" class="bg-amber-500 hover:bg-amber-600 text-white font-semibold px-8 py-3 rounded-full transition-colors">
        Browse the Shop
      </a>
      <a href="/blog" class="border border-stone-300 hover:border-stone-400 text-stone-700 font-semibold px-8 py-3 rounded-full transition-colors">
        Read the Blog
      </a>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-amber-600 text-sm font-semibold uppercase tracking-widest mb-1">New in shop</p>
          <h2 class="text-3xl font-bold text-stone-900">Featured Products</h2>
        </div>
        <a href="/shop" class="text-sm font-medium text-stone-500 hover:text-amber-600 transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featuredProducts.map(product => (
          <div class="group bg-stone-50 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="bg-stone-100 rounded-xl h-40 flex items-center justify-center text-5xl mb-5 group-hover:scale-105 transition-transform">
              {product.emoji}
            </div>
            <span class="text-xs font-semibold text-amber-600 uppercase tracking-widest">{product.tag}</span>
            <h3 class="font-semibold text-stone-900 mt-1 mb-1">{product.name}</h3>
            <p class="text-sm text-stone-500 mb-4">{product.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-stone-900">${product.price}</span>
              <button class="bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold px-4 py-2 rounded-full transition-colors">
                Add to cart
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About snippet -->
  <section class="max-w-5xl mx-auto px-6 py-20 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div class="bg-stone-200 rounded-3xl h-80 flex items-center justify-center text-8xl">
      🧑‍🎨
    </div>
    <div>
      <p class="text-amber-600 text-sm font-semibold uppercase tracking-widest mb-3">About me</p>
      <h2 class="text-3xl font-bold text-stone-900 mb-4">Hi, I'm Sukriti.</h2>
      <p class="text-stone-500 mb-4 leading-relaxed">
        I make things by hand — ceramics, textiles, prints — and write about the process of making. Everything in the shop is produced in small batches or one-of-a-kind runs.
      </p>
      <p class="text-stone-500 mb-6 leading-relaxed">
        I believe the objects we surround ourselves with matter, and that how they're made matters just as much as what they are.
      </p>
      <a href="/about" class="inline-flex items-center gap-2 text-amber-600 font-semibold hover:text-amber-700 transition-colors">
        Read more about me →
      </a>
    </div>
  </section>

  <!-- Featured Blog Posts -->
  <section class="bg-stone-900 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-amber-400 text-sm font-semibold uppercase tracking-widest mb-1">From the blog</p>
          <h2 class="text-3xl font-bold text-white">Latest Writing</h2>
        </div>
        <a href="/blog" class="text-sm font-medium text-stone-400 hover:text-white transition-colors">All posts →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featuredPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="bg-stone-800 rounded-2xl p-6 hover:bg-stone-700 transition-colors group">
            <span class="text-xs font-semibold text-amber-400 uppercase tracking-widest">{post.tag}</span>
            <h3 class="text-white font-semibold mt-2 mb-2 group-hover:text-amber-400 transition-colors">{post.title}</h3>
            <p class="text-stone-400 text-sm mb-4 leading-relaxed">{post.excerpt}</p>
            <p class="text-stone-500 text-xs">{post.date}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
