---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'getting-started-with-ceramics',
    title: 'Getting Started with Ceramics',
    date: 'March 28, 2026',
    excerpt: 'My journey into hand-building pottery — the tools, clay bodies, and first firings that changed everything.',
    tag: 'Craft',
    readTime: '6 min read',
  },
  {
    slug: 'design-principles-i-live-by',
    title: 'Design Principles I Live By',
    date: 'March 12, 2026',
    excerpt: 'Simplicity, intentionality, and leaving room for imperfection. How these ideas shape my work every day.',
    tag: 'Design',
    readTime: '4 min read',
  },
  {
    slug: 'small-batch-production',
    title: 'Why I Switched to Small Batch',
    date: 'February 20, 2026',
    excerpt: 'Dropping mass production in favour of limited runs — and why my work (and life) is better for it.',
    tag: 'Business',
    readTime: '5 min read',
  },
  {
    slug: 'natural-dyeing-basics',
    title: 'Natural Dyeing: A Beginner\'s Guide',
    date: 'February 5, 2026',
    excerpt: 'From plant to fibre — how I harvest, mordant, and dye textiles using nothing but what the garden provides.',
    tag: 'Craft',
    readTime: '8 min read',
  },
  {
    slug: 'on-selling-creative-work',
    title: 'On Selling Creative Work (Without Losing Your Soul)',
    date: 'January 18, 2026',
    excerpt: 'Pricing, platforms, and the question nobody talks about: how do you value something made with your hands?',
    tag: 'Business',
    readTime: '7 min read',
  },
  {
    slug: 'slow-studio-practice',
    title: 'Building a Slow Studio Practice',
    date: 'January 3, 2026',
    excerpt: 'What happens when you stop optimising for output and start optimising for attention? My experiment with slow making.',
    tag: 'Process',
    readTime: '5 min read',
  },
];
---

<Layout title="Blog" description="Writing about craft, design, and making things by hand.">
  <!-- Hero -->
  <section class="bg-white border-b border-stone-100 py-16">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-amber-600 text-sm font-semibold uppercase tracking-widest mb-3">Thoughts & process</p>
      <h1 class="text-4xl md:text-5xl font-bold text-stone-900 mb-4">The Blog</h1>
      <p class="text-stone-500 max-w-lg">
        Writing about craft, slow living, design, and what it means to make things by hand in a fast world.
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <!-- Featured post -->
    <a href={`/blog/${posts[0].slug}`} class="block bg-white rounded-3xl border border-stone-100 overflow-hidden hover:shadow-lg transition-shadow mb-8 md:flex group">
      <div class="bg-stone-100 md:w-80 h-52 md:h-auto flex items-center justify-center text-7xl flex-shrink-0">
        ✍️
      </div>
      <div class="p-8 flex flex-col justify-center">
        <div class="flex items-center gap-3 mb-3">
          <span class="bg-amber-100 text-amber-700 text-xs font-semibold px-3 py-1 rounded-full">{posts[0].tag}</span>
          <span class="text-stone-400 text-sm">{posts[0].readTime}</span>
        </div>
        <h2 class="text-2xl font-bold text-stone-900 mb-3 group-hover:text-amber-600 transition-colors">{posts[0].title}</h2>
        <p class="text-stone-500 mb-4 leading-relaxed">{posts[0].excerpt}</p>
        <p class="text-stone-400 text-sm">{posts[0].date}</p>
      </div>
    </a>

    <!-- Rest of posts -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.slice(1).map(post => (
        <a href={`/blog/${post.slug}`} class="bg-white rounded-2xl border border-stone-100 p-6 hover:shadow-md transition-shadow group block">
          <div class="flex items-center gap-3 mb-3">
            <span class="bg-stone-100 text-stone-600 text-xs font-semibold px-3 py-1 rounded-full">{post.tag}</span>
            <span class="text-stone-400 text-xs">{post.readTime}</span>
          </div>
          <h3 class="font-bold text-stone-900 mb-2 group-hover:text-amber-600 transition-colors">{post.title}</h3>
          <p class="text-stone-500 text-sm mb-4 leading-relaxed">{post.excerpt}</p>
          <p class="text-stone-400 text-xs">{post.date}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-stone-900 py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Get new posts by email</h2>
      <p class="text-stone-400 mb-8">No spam, no algorithms. Just new writing, straight to your inbox.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 bg-stone-800 border border-stone-700 text-white placeholder-stone-500 rounded-full px-5 py-3 focus:outline-none focus:border-amber-500"
        />
        <button type="submit" class="bg-amber-500 hover:bg-amber-600 text-white font-semibold px-6 py-3 rounded-full transition-colors whitespace-nowrap">
          Subscribe
        </button>
      </form>
    </div>
  </section>
</Layout>
